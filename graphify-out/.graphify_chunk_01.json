    {"id":"readme_security_guard","label":"Dynamic Security Guard (HITL)","file_type":"concept","source_file":"/home/blanco/builds/LLM-OS-AGENT/README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Filters file paths and shell commands; risky commands paused for Human-in-the-Loop approval; configured via security-config.json (allowed read/write dirs, allowed utilities, auto-approve, require-approval toggle)."},
    {"id":"readme_claude_fable_5","label":"Claude Fable 5 prompt option","file_type":"concept","source_file":"/home/blanco/builds/LLM-OS-AGENT/README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"1,000+ line behavioral prompt directive, stored as prompts/claude-fable-5.md."},

{"nodes": [{"id": "plan_implementation_plan", "label": "AegisAgent Implementation Plan", "file_type": "document", "source_file": "plan/IMPLEMENTATION-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The how; companion to REDESIGN-PLAN (what/why) and the mock (approved look). Six phases ordered so each ships something visible; commit per phase, run npm run verify. Phases 1-2 are the core ask; 3-4 change the security model; 5-6 additive; cut 6.3 first."}, {"id": "plan_implementation_plan_metrics", "label": "metrics.js real-usage wiring (Phase 1)", "file_type": "concept", "source_file": "plan/IMPLEMENTATION-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Parse LiteLLM usage into metrics.js; char-count heuristic kept only as fallback flagged source:'estimated'; add cost + per-model pricing map to createEmptyMetrics(); per-turn append-only ledger."}, {"id": "plan_implementation_plan_subagent_tracker", "label": "SubagentTracker wiring (Phase 1)", "file_type": "concept", "source_file": "plan/IMPLEMENTATION-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Register the dead subagent_tool_start/end + reasoning listeners in server.js; invoke SubagentTracker.startToolCall/endToolCall and metrics.addSubagent family (implemented but never called); fix parentId=null hardcoding; serialize toJSON/fromJSON into the session row so traces survive restart."}, {"id": "plan_implementation_plan_protocol", "label": "WS event vocabulary (PROTOCOL.md)", "file_type": "concept", "source_file": "plan/IMPLEMENTATION-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One WS event vocabulary feeding the timeline: turn_start, reasoning, tool_start/end, edit, subagent_spawn, subagent_event, approval_request/resolved, usage_update, assistant_message. Documented in agent-backend/PROTOCOL.md."}, {"id": "plan_implementation_plan_devices_table", "label": "devices table + pair endpoints (Phase 3)", "file_type": "concept", "source_file": "plan/IMPLEMENTATION-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "POST /api/pair/start (5-min OTP, owner-only) + /api/pair/claim (code+name+scope -> device token); token check on every HTTP route and WS upgrade replaces the fail-open middleware; scopes chat_voice/read_only/full enforced server-side; revocation kills sockets."}, {"id": "plan_implementation_plan_harness_instances", "label": "harness_instances registry (Phase 3)", "file_type": "concept", "source_file": "plan/IMPLEMENTATION-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "harness_instances table (type, transport, machine, policy scope, status); local=spawn, remote=aegis-adapter over authenticated WS; multiple per machine; sessions keyed (deviceId, sessionId); removes kill-sibling-session behavior."}], "edges": [{"source": "plan_implementation_plan", "target": "plan_redesign_plan", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "plan/IMPLEMENTATION-PLAN.md", "source_location": null, "weight": 1.0}, {"source": "plan_implementation_plan", "target": "plan_aegis_console_mock", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "plan/IMPLEMENTATION-PLAN.md", "source_location": null, "weight": 1.0}, {"source": "plan_implementation_plan_metrics", "target": "plan_redesign_plan_usage_accounting", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "plan/IMPLEMENTATION-PLAN.md", "source_location": null, "weight": 1.0}, {"source": "plan_implementation_plan_subagent_tracker", "target": "plan_rede
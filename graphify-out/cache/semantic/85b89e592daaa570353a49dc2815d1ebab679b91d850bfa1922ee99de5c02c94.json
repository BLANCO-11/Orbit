{"nodes": [{"id": "plan_redesign_plan", "label": "AegisAgent Product Redesign Plan", "file_type": "document", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The what/why; dated 2026-07-10; supersedes all earlier plan docs; declares the mock the source of truth for target UI."}, {"id": "plan_redesign_plan_aegisagent", "label": "Local-first agent-operations console", "file_type": "rationale", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Like Cursor's agent panel but harness-agnostic and self-hosted: harnesses do the work, devices drive it, connectors extend it, skills specialize it, policies govern it, everything observable, voice first-class."}, {"id": "plan_redesign_plan_console", "label": "Console surface", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sessions list + unified timeline (toggle to Mission view) + contextual inspector + composer."}, {"id": "plan_redesign_plan_fleet", "label": "Fleet surface", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pairs devices and harnesses via one OTP flow; harness registry + device registry with revoke. Killed the old 'Paired devices 0' footer row."}, {"id": "plan_redesign_plan_connectors_surface", "label": "Connectors surface", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Own page for the MCP tool-server registry, moved out of Fleet. Skills = instructions; connectors = tools."}, {"id": "plan_redesign_plan_policies_surface", "label": "Policies surface", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The whole authorization story on one screen: capability x mode matrix, budgets, per-device overrides."}, {"id": "plan_redesign_plan_settings", "label": "Settings surface", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One page on the rail: models, prompt directives, skills, voice, memory/compaction. Killed the second settings entry point."}, {"id": "plan_redesign_plan_unified_timeline", "label": "Unified timeline", "file_type": "rationale", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One chronological stream \u2014 chat woven in, not a separate column. Entry types: user message, plan card, tool call, edit card, reasoning accordion, sub-agent lane, approval gate, assistant message. The work is the centerpiece; replaces chat+hidden-tabs."}, {"id": "plan_redesign_plan_mission_view", "label": "Mission view", "file_type": "rationale", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A lens, not a tab: the same session data projected as the agent's own phase breakdown \u2014 tasks with owner (main or sub-agent), status, cross-check gates, re-plans tagged with the reasoning turn that introduced them. Deep-effort sessions get it by default; never a second source of truth."}, {"id": "plan_redesign_plan_inspector", "label": "Inspector (Overview/Workspace/Preview/Trace)", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "348px contextual right panel with four segments; replaces the old 5-tab panel where one tab was clipped offscreen. Overview = usage tiles + tokens-per-turn chart + context/budget meters + sub-agent list + latency; Trace = end-to-end per-sub-agent detail."}, {"id": "plan_redesign_plan_composer", "label": "Composer (compact)", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single-line textarea + one quiet row of uniform accordion chips: mode, harness, prompt, effort, skills, plus dictate mic, TTS toggle, Send."}, {"id": "plan_redesign_plan_prompt_library", "label": "Prompt library", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Stored system prompts (standard + claude/gemini/codex frontier-style flavors) selected per session; inherited by the main agent AND every sub-agent it spawns; mode directives appended on top, not mixed in. Add by paste/file/URL."}, {"id": "plan_redesign_plan_permission_mode", "label": "Permission mode (Chat/Plan/Edit/Yolo)", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One of two orthogonal session axes \u2014 what the agent MAY do."}, {"id": "plan_redesign_plan_effort_profile", "label": "Effort profile (fast/balanced/deep)", "file_type": "rationale", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Effort != permission. A composer profile = model routing + reasoning budget; deliberately kept orthogonal to permission mode. Two axes, not seven modes. Defaults editable in Settings."}, {"id": "plan_redesign_plan_harness", "label": "Harness", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Harnesses do the work \u2014 pi-code today, opencode/any CLI tomorrow via an adapter protocol. Local (child process) or remote (WS + token). Multiple per machine, each with its own policy scope."}, {"id": "plan_redesign_plan_device", "label": "Device", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Laptop, phone, tablet \u2014 drive the console. Paired via URL + OTP with a scope chosen at pairing (chat+voice / read-only / full control). devices table (id, name, scope, token-hash, created, last_seen); revocation kills token + live sockets."}, {"id": "plan_redesign_plan_otp_pairing", "label": "OTP pairing", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One flow pairs both devices and harnesses: URL + short-lived (~5 min) OTP; success mints a long-lived token; WS upgrade authenticates it. Scope chosen at pairing time."}, {"id": "plan_redesign_plan_adapter_protocol", "label": "aegis-adapter protocol", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "CLI (npx aegis-adapter --code ...) that claims an OTP, opens an authenticated WS, and bridges a remote harness's stdio protocol. Any CLI that speaks it can connect."}, {"id": "plan_redesign_plan_connectors_mcp", "label": "Connectors (MCP tool-server registry)", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "MCP servers (command or URL + auth) registered once; tools namespaced connector.tool; exposed to every harness session; every call passes the policy engine and lands in timeline+metrics like any tool. github is the reference connector; lightpanda already exists."}, {"id": "plan_redesign_plan_skills", "label": "Skills (instruction packs)", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Directory of instruction packs (skills/<name>/SKILL.md); session-attach injects into the system prompt; always-on flag in Settings. Reusable, per-session or always-on."}, {"id": "plan_redesign_plan_policy_engine", "label": "Policy engine v2 (capability x mode matrix)", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Capability x mode matrix (allow/ask/block) replacing the single global config blob and AEGIS_MODE env fallback; scoped per device and per harness with overrides; 'ask' emits an approval_request event; budgets enforced server-side (pause at cap). Hot-reloads per instance."}, {"id": "plan_redesign_plan_budgets", "label": "Budgets & limits (enforced)", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Enforced not advisory: max cost/session, token budget, sub-agent depth; harness paused at cap with a timeline gate asking to continue."}, {"id": "plan_redesign_plan_approval_gate", "label": "In-timeline approval gate", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Approvals happen in place: policy 'ask' renders a gate card in the timeline at the moment the action fires (Approve once / Deny), no modal, no separate queue; only devices with approval rights resolve; resolution broadcast to all viewers."}, {"id": "plan_redesign_plan_subagent_observability", "label": "Sub-agent observability (end-to-end)", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every spawn records task, parent, depth; sub-agent reasoning + tools captured; each sub-agent gets its own trace (task, reasoning, tools, metrics) that streams live and is persisted. First-class nested lanes with lineage color."}, {"id": "plan_redesign_plan_usage_accounting", "label": "Provider-reported usage accounting", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Parse provider usage (prompt/completion tokens) from LiteLLM responses; per-model pricing map -> cost; persisted per turn AND per agent. The word 'estimated' disappears from the UI."}, {"id": "plan_redesign_plan_tts", "label": "TTS / voice (first-class I/O)", "file_type": "concept", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sentence-level TTS pipeline stays; mute stops playback immediately; barge-in (mic activity pauses audio); blob URLs revoked; reasoning and tool output are never spoken."}, {"id": "plan_redesign_plan_design_system", "label": "Design system (from the mock)", "file_type": "rationale", "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Dark-committed ops console; ground #0f0f13, accent iris #8781ec; status colors never used as chart series; chart series in #8781ec / out #1baf7a (CVD+contrast validated); monospace is the data voice. Real semantics: role=tab, focus-visible, no @ts-nocheck / props:any."}], "edges": [{"source": "plan_redesign_plan", "target": "plan_aegis_console_mock", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "weight": 1.0}, {"source": "readme_claude_fable_5", "target": "plan_redesign_plan_prompt_library", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "weight": 1.0}, {"source": "readme_security_guard", "target": "plan_redesign_plan_policy_engine", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.8, "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "weight": 1.0}, {"source": "readme_mcp", "target": "plan_redesign_plan_connectors_mcp", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "weight": 1.0}, {"source": "plan_redesign_plan_connectors_mcp", "target": "readme_lightpanda", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "weight": 1.0}, {"source": "readme_voice_io", "target": "plan_redesign_plan_tts", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "weight": 1.0}, {"source": "plan_redesign_plan", "target": "plan_redesign_plan_aegisagent", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "plan/REDESIGN-PLAN.md", "source_location": null, "weight": 1.0}, {"source": "plan_redesign_plan_console", "target": "plan_redesign_plan_unified_timeline", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file
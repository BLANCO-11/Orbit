# ── Orbit environment ────────────────────────────────────────────────
# Copy to `.env` and fill in. Everything here is optional EXCEPT an LLM endpoint
# (set it here or in the app's Settings). Values here override security-config.json.

# ── Core ──
PORT=6800                                   # backend (loopback only)
DASHBOARD_ORIGIN=http://localhost:6801      # dashboard origin (CORS)
# ORBIT_API_KEY=                            # if set, the API + WS require this bearer token; unset = loopback, no auth
# ORBIT_HOME=~/.orbit                        # where per-session workspaces live (default ~/.orbit)

# ── LLM (REQUIRED — via any OpenAI-compatible endpoint, e.g. LiteLLM) ──
LITELLM_BASE_URL=http://127.0.0.1:5000/v1
LITELLM_KEY=sk-your-key
LITELLM_MODEL=your-model-id

# ── Harness binaries (auto-discovered if installed on PATH; override if needed) ──
# PI_CLI_PATH=/path/to/pi
# PI_NODE_PATH=/path/to/node
# OPENCODE_PATH=opencode                    # for the OpenCode harness (npm i -g opencode-ai)

# ── Browser (Lightpanda; auto-started via Docker on boot) ──
# LIGHTPANDA_WS=ws://127.0.0.1:9222
# ORBIT_SANDBOX_IMAGE=node:22-slim          # image for the container sandbox

# ── Text-to-Speech (OPTIONAL — the voice UI only appears when these are set) ──
# LOCAL_TTS_URL=http://127.0.0.1:6767
# LOCAL_TTS_KEY=
# LOCAL_TTS_MODEL=pocket-tts

# ── Web search backends (OPTIONAL — for pi's native web_search; Orbit ships a keyless search MCP too) ──
# EXA_API_KEY=
# PERPLEXITY_API_KEY=
# GEMINI_API_KEY=

# ── Telegram (OPTIONAL — bot token is added encrypted via the Connectors UI, not here) ──
# TELEGRAM_DISABLE=1                        # set to disable the Telegram poller entirely

# ── Database (default: local SQLite at agent-backend/*.db) ──
# DATABASE_URL=postgres://user:pass@host:5432/orbit   # (planned) switch to a cloud Postgres; SQLite is used today
